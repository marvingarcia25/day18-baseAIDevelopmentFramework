{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://localhost:5080",
  "FrontendOrigin": "http://localhost:5173",

  // Which LLM serves /api/chat, /api/agent, and /api/rag/ask.
  // Provider: "anthropic" (ANTHROPIC_API_KEY) | "openai" (OPENAI_API_KEY) | "ollama" (local, no key).
  // Optional keys: "Model", "ApiKey", "BaseUrl" — omitted values use sensible defaults.
  // Override via env vars too, e.g. Llm__Provider=ollama Llm__Model=llama3.1
  "Llm": {
    "Provider": "anthropic"
  },

  // Embeddings for RAG. "hashing" is offline (no key, demo-quality retrieval);
  // switch to "openai" or "ollama" for real semantic search. See docs/rag.md.
  "Embeddings": {
    "Provider": "hashing"
  }
}
